# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=paper_agent
DATABASE_URL=postgresql://postgres:postgres@db:5432/paper_agent

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-nano

# Crossref polite-pool contact (no API key needed). Use a real email so Crossref
# can reach you if your automated traffic ever misbehaves.
CROSSREF_MAILTO=you@example.com

# Elsevier (Scopus) Search API key — enables the search_scopus tool.
# Get one at https://dev.elsevier.com/. Optional; leave blank to disable the tool.
# Note: full Scopus results may require your institution's network/subscription.
ELSEVIER_API_KEY=your_elsevier_api_key_here

# Authentication (JWT) — CHANGE THIS to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Human-in-the-loop. false (default) = the agent runs its whole plan and returns
# the final result. true = sensitive tools (analytics_sandbox, screen_abstracts_csv,
# ingest_pdf, draft_paper_section, compile_paper) pause for approve/edit/reject.
REQUIRE_TOOL_APPROVAL=false

# LangSmith Configuration
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=paper-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
